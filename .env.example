# ============================================
# SISAM - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha com valores reais
# NUNCA commite o arquivo .env com credenciais reais

# Banco de Dados (Supabase PostgreSQL)
DB_HOST=seu-host.supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USER=seu-usuario
DB_PASSWORD=sua-senha-segura-aqui
DB_SSL=true

# Autenticação JWT (mínimo 32 caracteres, gere com: openssl rand -hex 32)
JWT_SECRET=gere-uma-chave-com-openssl-rand-hex-32

# Ambiente
NODE_ENV=development

# URL da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis Cache (opcional - Upstash)
# UPSTASH_REDIS_REST_URL=https://seu-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=seu-token-redis

# ============================================
# E-mail (Resend) — Fase 1 SEMED
# ============================================
# Necessário para recuperação de senha, 2FA e notificações LGPD.
# Crie conta em https://resend.com e gere uma API key.
# Em desenvolvimento, sem RESEND_API_KEY o sistema usa modo dry-run (apenas log).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=SISAM/SEMED <noreply@seu-dominio.gov.br>

# ============================================
# Observabilidade (Sentry) — Fase 1 SEMED
# ============================================
# Para capturar erros de produção. Crie projeto em https://sentry.io
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_xxx     # apenas para upload de source maps
# SENTRY_ORG=sua-org
# SENTRY_PROJECT=sisam

# ============================================
# Logger — Fase 1 SEMED
# ============================================
# LOG_LEVEL=info               # debug | info | warn | error
# LOG_ENABLED=true             # false desabilita por completo
# LOG_MASK_PII=true            # false desabilita mascaramento (apenas dev)

# ============================================
# Push (Firebase Cloud Messaging) — notificações ao responsável
# ============================================
# Necessário para push (ex: alerta de infrequência — Fase 4.1).
# Sem FIREBASE_SERVICE_ACCOUNT_KEY o envio de push é no-op (não falha).
# Server (JSON da service account, em uma linha):
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Client (browser, expostos como NEXT_PUBLIC):
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ============================================
# Cron jobs (health-check, notificar-infrequencia) — Fase 4.1
# ============================================
# Bearer token exigido no header Authorization dos endpoints /api/cron/*.
# Gere com: openssl rand -hex 32
# CRON_SECRET=gere-uma-chave-com-openssl-rand-hex-32
