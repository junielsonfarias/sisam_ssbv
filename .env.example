# ============================================
# SISAM - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha com valores reais
# NUNCA commite o arquivo .env com credenciais reais

# Banco de Dados (Supabase PostgreSQL)
DB_HOST=seu-host.supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USER=seu-usuario
DB_PASSWORD=sua-senha-segura-aqui
DB_SSL=true

# Autenticação JWT (mínimo 32 caracteres, gere com: openssl rand -hex 32)
JWT_SECRET=gere-uma-chave-com-openssl-rand-hex-32

# Ambiente
NODE_ENV=development

# URL da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis Cache (opcional - Upstash)
# UPSTASH_REDIS_REST_URL=https://seu-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=seu-token-redis
